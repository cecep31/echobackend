# Config uses scoped keys where noted (DB_POOL_*, S3_*, APP_*).

# Server
PORT=8080

# Auth
# JWT_SECRET must be at least 32 characters long.
JWT_SECRET=
JWT_EXPIRY_HOURS=3
REFRESH_TOKEN_EXPIRY_DAYS=30

# GitHub OAuth (leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/oauth/github/callback

# Frontend (used for OAuth redirects and cookies)
FRONTEND_URL=http://localhost:3000
FRONTEND_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
MAIN_DOMAIN=localhost

# Database
# DATABASE_URL is required (PostgreSQL connection DSN)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable

# Database connection pool
# DB_POOL_MAX_OPEN (alias: MAX_OPEN_CONNS)
DB_POOL_MAX_OPEN=50
# DB_POOL_MAX_IDLE (alias: MAX_IDLE_CONNS)
DB_POOL_MAX_IDLE=2
# DB_POOL_CONN_LIFETIME (alias: CONN_MAX_LIFETIME)
DB_POOL_CONN_LIFETIME=3m

# goose migration
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=${DATABASE_URL}
GOOSE_MIGRATION_DIR=./migrations
GOOSE_TABLE=custom.goose_migrations

# Global HTTP rate limit: sustained requests per second (0 = disabled).
# This global limiter is token-bucket based.
# HTTP_RATE_LIMIT_RPS (alias: RATE_LIMITER_MAX)
HTTP_RATE_LIMIT_RPS=0
# HTTP_RATE_LIMIT_WINDOW_SEC (alias: RATE_LIMITER_TTL) - controls visitor cleanup TTL.
HTTP_RATE_LIMIT_WINDOW_SEC=0

# When true, client IP for RealIP()/logging uses X-Forwarded-For (use behind a trusted reverse proxy).
# HTTP_TRUST_PROXY (alias: TRUST_PROXY)
HTTP_TRUST_PROXY=false

# CORS allowed origins. Use "*" for any origin, or comma-separated list (e.g. "https://app.com,https://admin.com").
HTTP_ALLOW_ORIGINS=*

# S3-compatible storage (MinIO, AWS S3, …)
# S3_ENDPOINT (alias: MINIO_ENDPOINT)
S3_ENDPOINT=localhost:9000
# S3_ACCESS_KEY (alias: MINIO_ACCESS_KEY)
S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY (alias: MINIO_SECRET_KEY)
S3_SECRET_KEY=minioadmin
# S3_BUCKET (alias: MINIO_BUCKET)
S3_BUCKET=minio-bucket
# S3_USE_SSL (alias: MINIO_USE_SSL)
S3_USE_SSL=true

# Valkey / Redis cache for random posts, OAuth exchange codes, and distributed auth rate limits.
# REDIS_URL (alternative: VALKEY_URL) - Leave empty to use in-memory fallbacks where available.
REDIS_URL=
CACHE_KEY_PREFIX=pilput
CACHE_TTL_SECONDS=60
# REDIS_CONNECT_TIMEOUT_MS (alias: VALKEY_CONNECT_TIMEOUT_MS)
REDIS_CONNECT_TIMEOUT_MS=5000

# Background job queue (Asynq).
# QUEUE_REDIS_URL (aliases: ASYNQ_REDIS_URL, REDIS_URL, VALKEY_URL) - falls back to REDIS_URL/VALKEY_URL when empty.
QUEUE_REDIS_URL=${REDIS_URL}
# QUEUE_REDIS_TIMEOUT_MS (aliases: ASYNQ_REDIS_TIMEOUT_MS, REDIS_CONNECT_TIMEOUT_MS, VALKEY_CONNECT_TIMEOUT_MS)
QUEUE_REDIS_TIMEOUT_MS=5000
QUEUE_DEFAULT_NAME=default
QUEUE_CONCURRENCY=1
QUEUE_MAX_RETRY=5

# OpenRouter AI chat. Leave OPENROUTER_API_KEY empty to disable AI responses (stream endpoints return user message only).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openrouter/free
OPENROUTER_HTTP_REFERER=https://pilput.net
OPENROUTER_TITLE=pilput
OPENROUTER_TIMEOUT_SECONDS=90

# Email Configuration (SMTP for password reset)
# Leave SMTP_HOST empty to disable delivery and keep dev-mode reset links in activity metadata.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# SMTP_FROM (alias: EMAIL_FROM)
SMTP_FROM=noreply@pilput.net
# Set true for implicit TLS, usually port 465. Leave false for STARTTLS, usually port 587.
SMTP_TLS=false
# Per SMTP network operation timeout.
SMTP_TIMEOUT_SECONDS=10
# Overall Asynq task timeout for one email delivery attempt.
SMTP_TASK_TIMEOUT_SECONDS=30

# Enable debug logging, GORM info logs, and debug routes.
# APP_DEBUG (alias: DEBUG)
APP_DEBUG=false
