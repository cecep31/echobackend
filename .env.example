# Config uses scoped keys where noted (DB_POOL_*, S3_*, APP_*).

# Server
PORT=8080

# Auth
JWT_SECRET=your-secret-key
JWT_EXPIRY_HOURS=3

# GitHub OAuth (leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/oauth/github/callback

# Frontend (used for OAuth redirects and cookies)
FRONTEND_URL=http://localhost:3000
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
MAIN_DOMAIN=localhost

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable

# Database connection pool
DB_POOL_MAX_OPEN=50
DB_POOL_MAX_IDLE=2
DB_POOL_CONN_LIFETIME=3m

# goose migration
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=${DATABASE_URL}
GOOSE_MIGRATION_DIR=./migrations
GOOSE_TABLE=custom.goose_migrations

# Global HTTP rate limit: sustained requests per second (0 = disabled).
# When HTTP_RATE_LIMIT_WINDOW_SEC > 0, sets Echo rate limit store visitor ExpiresIn (seconds).
HTTP_RATE_LIMIT_RPS=0
HTTP_RATE_LIMIT_WINDOW_SEC=0

# When true, client IP for RealIP()/logging uses X-Forwarded-For (use behind a trusted reverse proxy).
HTTP_TRUST_PROXY=false

# CORS allowed origins. Use "*" for any origin, or comma-separated list (e.g. "https://app.com,https://admin.com").
HTTP_ALLOW_ORIGINS=*

# S3-compatible storage (MinIO, AWS S3, …)
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=minio-bucket
S3_USE_SSL=false

# Valkey cache for random posts. Leave VALKEY_URL empty to disable caching.
VALKEY_URL=
CACHE_KEY_PREFIX=pilput
CACHE_TTL_SECONDS=60
VALKEY_CONNECT_TIMEOUT_MS=5000

APP_DEBUG=false
